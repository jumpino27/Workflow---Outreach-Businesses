# =============================================================================
#  LOCAL BUSINESS OUTREACH AGENT  —  CONFIGURATION
# =============================================================================
#  Every value below was hard-coded in the original manual.
#  Now it lives here so ANY operator can make this workflow their own
#  by editing this one file. No need to touch business-outreach.md.
#
#  How to use: change the values on the right of each "=" sign.
#  Keep the names on the left exactly as they are.
#  Lines starting with "#" are comments and are ignored.
# =============================================================================


# -----------------------------------------------------------------------------
#  0. SECRETS / API KEYS   ⚠️  KEEP THESE PRIVATE — NEVER COMMIT A REAL KEY
# -----------------------------------------------------------------------------
# The /image skill (.claude/skills/image/image.py) reads this key from THIS file
# to generate the preview images. Paste your real OpenAI key here LOCALLY.
# This file is git-ignored, so your real key stays on your machine. (The public
# repo ships `.env.example` as the template instead.)
OPENAI_API_KEY="sk-REPLACE-WITH-YOUR-OPENAI-KEY"


# -----------------------------------------------------------------------------
#  1. WHO YOU ARE  (used in every email signature + on document.html / me.html)
# -----------------------------------------------------------------------------
OPERATOR_NAME="Gabriel Stancuta"
BRAND_NAME="Jumping Tech"
MAIN_WEBSITE="jumpinotech.com"
HOME_BASE="South Tyrol (Südtirol / Alto Adige), Italy"

# A short location line that goes in your email signature (compliance: postal reference)
SIGNATURE_LOCATION="Jumping Tech · South Tyrol, Italy · jumpinotech.com"

# Your reply-to email (where prospects answer you). Keep it a real inbox you read.
REPLY_TO_EMAIL="hello@jumpinotech.com"


# -----------------------------------------------------------------------------
#  2. LANGUAGES
# -----------------------------------------------------------------------------
# Your own preferred language for real back-and-forth conversations.
OPERATOR_MAIN_LANGUAGE="Italian"
# Other languages you speak fluently (comma separated).
OPERATOR_FLUENT_LANGUAGES="English, Romanian"
# Languages you only handle at a basic level (offer to switch away from these).
OPERATOR_BASIC_LANGUAGES="German"
# When a basic-language prospect replies, the friendly "let's switch" line:
SWITCH_LANGUAGE_NOTE="Antworte gern auf Italienisch oder Englisch, das geht für mich am schnellsten."


# -----------------------------------------------------------------------------
#  3. WHAT YOU BUILD  (drives the pitch + which tiers/apps you offer)
# -----------------------------------------------------------------------------
# Platforms you can deliver apps for. Original: Windows, Android, browser (NO iOS/macOS).
APP_PLATFORMS="Windows, Android, Browser"
APP_PLATFORMS_EXCLUDED="iOS, macOS"
# One-line positioning hook used in pitches.
POSITIONING_HOOK="A local South Tyrolean who builds modern sites and full web/Windows/Android apps, and corresponds personally in Italian and English — not a faceless foreign agency."


# -----------------------------------------------------------------------------
#  4. OPERATING MODE
# -----------------------------------------------------------------------------
# LOCAL  = your home turf (South Tyrol framing, "local neighbour" pitch, document.html)
# AWAY   = anywhere else (remote/worldwide pitch, me.html, 30%-below-market pricing)
OPERATING_MODE="LOCAL"


# -----------------------------------------------------------------------------
#  5. PRICING  —  LOCAL MODE  (in EUR)
# -----------------------------------------------------------------------------
# Tier A: one beautiful landing page that routes to phone/email/booking. No backend.
PRICE_TIER_A="400"
PRICE_TIER_A_LABEL="Small landing page"

# Tier B: full / multi-page site with real functions (contact form + email, reviews,
# booking, gallery, longer content). Position within the range by pages/features.
PRICE_TIER_B_MIN="1200"
PRICE_TIER_B_MAX="2000"
PRICE_TIER_B_LABEL="Full website"

# Tier C: app / web-app (portal, booking system, internal tool). Always custom.
PRICE_TIER_C_LABEL="App / Web-App — custom, priced by needs"

# Yearly upkeep added to Tier A & B (domain + business email + maintenance).
PRICE_YEARLY_UPKEEP="100"

# Currency symbol used on the client pages.
CURRENCY_SYMBOL="€"


# -----------------------------------------------------------------------------
#  6. PRICING  —  AWAY MODE
# -----------------------------------------------------------------------------
# When operating abroad: research the typical LOCAL agency price for that market,
# then quote this percentage BELOW it. Never reuse the South Tyrol € numbers abroad.
AWAY_DISCOUNT_PERCENT="30"


# -----------------------------------------------------------------------------
#  7. PIPELINE LIMITS & TARGETS
# -----------------------------------------------------------------------------
# Hard cap: max businesses fully processed (package built) per run.
MAX_BUSINESSES_PER_RUN="10"
# Daily hand-sent email volume (keep it human + compliant).
DAILY_SEND_VOLUME="10"
# Email length target for the first touch (words).
FIRST_TOUCH_MAX_WORDS="80"
# Deliverability targets.
TARGET_BOUNCE_RATE_PERCENT="3"
TARGET_REPLY_RATE_PERCENT="8-15"
# Opt-out keyword a prospect can reply with to be removed forever.
OPT_OUT_KEYWORD="STOP"


# -----------------------------------------------------------------------------
#  8. FILE / STATE PATHS  (where the agent keeps its memory)
# -----------------------------------------------------------------------------
# Root folder that holds done.md + the per-business folders. The agent reads this first.
OUTREACH_ROOT="./outreach"
DONE_LEDGER="./outreach/done.md"
BUSINESSES_DIR="./outreach/businesses"
# Base client pages to personalise per business.
CLIENT_PAGE_LOCAL="./templates/document.html"
CLIENT_PAGE_AWAY="./templates/me.html"


# -----------------------------------------------------------------------------
#  9. COMPLIANCE  (do not weaken these unless you know the law in your market)
# -----------------------------------------------------------------------------
# Only email generic mailboxes (info@, office@, kontakt@…), never named personal ones.
PREFER_GENERIC_ADDRESSES_ONLY="true"
# Never email Italian PEC / certified-mail addresses.
DISCARD_PEC_ADDRESSES="true"
# Pixel/open tracking OFF (Italy's Garante treats pixels like cookies). Measure replies.
TRACKING_PIXELS="off"
# Default to the strictest country standard when unsure (Germany / UWG).
DEFAULT_TO_STRICTEST_RULE="true"
# How long to retain a lead that never engaged (years).
LEAD_RETENTION_YEARS="3"


# -----------------------------------------------------------------------------
#  10. DATA SOURCE DISCLOSURE  (the honest "how I found you" line per channel)
# -----------------------------------------------------------------------------
SOURCE_LINE_MAPS_DE="Ich habe euch über euer öffentliches Google-Maps-Profil gefunden."
SOURCE_LINE_MAPS_IT="Vi ho trovati tramite il vostro profilo pubblico su Google Maps."
SOURCE_LINE_MAPS_EN="I found you via your public Google Maps listing."
